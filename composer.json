{
    "name": "d3vi1/syno-transmission-manager",
    "description": "Native Synology DSM package for Transmission BitTorrent client",
    "type": "project",
    "license": "AGPL-3.0-or-later",
    "autoload": {
        "classmap": [
            "webapi/src/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        },
        "classmap": [
            "tests/Support/"
        ]
    },
    "require": {
        "php": ">=7.4",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-sqlite3": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "7.4.33"
        }
    }
}
