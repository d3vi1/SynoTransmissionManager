#!/bin/bash
set -euo pipefail

# Service control script for TransmissionManager
#
# TransmissionManager is a web UI package — it does not manage the
# Transmission daemon directly.  The daemon is assumed to be running
# independently.  This script handles package-level health and
# readiness checks required by DSM 7.
#
# DSM calls this script with one of: start | stop | status
# Exit 0 = running/ok, Exit 1 = stopped/error

PACKAGE="TransmissionManager"
PKG_DIR="/var/packages/$PACKAGE"
CONFIG_DIR="$PKG_DIR/var"
RUN_FILE="$CONFIG_DIR/.package_running"

log() {
    logger -t "$PACKAGE" "$1"
}

case "${1:-}" in
    start)
        log "Starting $PACKAGE..."

        # Ensure config directory exists
        if [ ! -d "$CONFIG_DIR" ]; then
            log "ERROR: Config directory missing: $CONFIG_DIR"
            exit 1
        fi

        # Verify database exists (created by postinst)
        if [ ! -f "$CONFIG_DIR/transmission.db" ]; then
            log "WARNING: Database not found, it will be created on first use"
        fi

        # Verify config.json exists
        if [ ! -f "$CONFIG_DIR/config.json" ]; then
            log "ERROR: Configuration file missing: $CONFIG_DIR/config.json"
            exit 1
        fi

        # Mark package as running
        touch "$RUN_FILE"
        log "$PACKAGE started successfully"
        exit 0
        ;;

    stop)
        log "Stopping $PACKAGE..."

        # Remove running marker
        rm -f "$RUN_FILE"

        log "$PACKAGE stopped"
        exit 0
        ;;

    status)
        if [ -f "$RUN_FILE" ]; then
            exit 0
        else
            exit 1
        fi
        ;;

    *)
        echo "Usage: $0 {start|stop|status}" >&2
        exit 1
        ;;
esac
